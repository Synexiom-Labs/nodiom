{
  "name": "@synexiom-labs/nodiom",
  "version": "0.1.1",
  "description": "Address any node in your Markdown. A structured read/write engine for Markdown documents.",
  "keywords": [
    "markdown",
    "ast",
    "mdast",
    "remark",
    "parser",
    "ai-agent",
    "structured"
  ],
  "author": "Synexiom Labs Inc.",
  "license": "MIT",
  "homepage": "https://github.com/Synexiom-Labs/nodiom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Synexiom-Labs/nodiom.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
